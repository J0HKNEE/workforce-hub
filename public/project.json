{
  "project": {
    "name": "Workforce Attendance & Headcount",
    "slug": "workforce",
    "version": "1.1.0",
    "description": "Static, GitHub-hosted dashboard for staffing, attendance, occurrences, corrective actions, perfect attendance, and shift coverage. Data lives in CSVs committed to the repo.",
    "repository": "https://github.com/J0HKNEE/Workforce.git",
    "hosting": {
      "type": "GitHub Pages",
      "auth": "none (repo-level access control)",
      "data_source": "CSV files in /public/data/",
      "deploy_workflow": ".github/workflows/deploy.yml"
    },
    "stack": {
      "framework": "TanStack Start v1 (React 19)",
      "bundler": "Vite 7",
      "styling": "Tailwind CSS v4",
      "ui": "shadcn/ui",
      "charts": "Recharts",
      "icons": "lucide-react",
      "data": "@tanstack/react-query"
    }
  },
  "roles": {
    "Admin": ["full read", "manage CSVs via git"],
    "HR": ["full read", "manage CSVs via git"],
    "Manager": ["read-only dashboards"]
  },
  "data_model": {
    "employees_csv": {
      "path": "public/data/employees.csv",
      "fields": [
        { "name": "employee_id", "type": "string" },
        { "name": "name", "type": "string" },
        { "name": "team", "type": "string" },
        { "name": "location", "type": "string" },
        { "name": "manager", "type": "string" },
        { "name": "status", "type": "enum", "values": ["Active", "Inactive"] }
      ]
    },
    "attendance_csv": {
      "path": "public/data/attendance.csv",
      "fields": [
        { "name": "date", "type": "date", "format": "YYYY-MM-DD" },
        { "name": "employee_id", "type": "string" },
        { "name": "type", "type": "enum", "values": ["Present", "Absent", "PTO", "ShortShift", "Makeup"] },
        { "name": "hours", "type": "number" },
        { "name": "occurrence", "type": "boolean" },
        { "name": "occurrence_reason", "type": "enum", "values": ["", "Absence", "Tardy", "LeaveEarly"] },
        { "name": "notes", "type": "string" }
      ]
    },
    "coverage_targets_csv": {
      "path": "public/data/coverage_targets.csv",
      "fields": [
        { "name": "team", "type": "string" },
        { "name": "location", "type": "string" },
        { "name": "expected_per_day", "type": "number" }
      ]
    }
  },
  "business_rules": {
    "occurrence_definition": {
      "Absence": "Unapproved missed shift",
      "Tardy": ">= 15 minutes late at start of shift, after lunch, or after break",
      "LeaveEarly": ">= 15 minutes before end of shift"
    },
    "corrective_actions_rolling_3_months": [
      { "occurrences": 3, "action": "Verbal Corrective Action" },
      { "occurrences": 4, "action": "Written Corrective Action" },
      { "occurrences": 5, "action": "Final Corrective Action" },
      { "occurrences": 6, "action": "Termination eligible" }
    ],
    "corrective_actions_rolling_12_months": [
      { "finals": 3, "action": "Termination eligible" }
    ],
    "perfect_attendance": {
      "window": "Any 3-month range (user-selectable)",
      "disqualifiers": ["Absent", "Tardy >= 15 min", "LeaveEarly >= 15 min", "ShortShift"],
      "neutral": ["PTO", "Makeup"]
    },
    "shift_coverage": {
      "working_types": ["Present", "Makeup", "ShortShift"],
      "expected_source": "coverage_targets.csv (team x location x expected_per_day)",
      "actual_metric": "average working headcount per day across selected range",
      "coverage_pct": "actual_per_day / expected_per_day"
    }
  },
  "routes": [
    { "path": "/", "file": "src/routes/index.tsx", "label": "Today" },
    { "path": "/calendar", "file": "src/routes/calendar.tsx", "label": "Calendar" },
    { "path": "/coverage", "file": "src/routes/coverage.tsx", "label": "Shift Coverage" },
    { "path": "/occurrences", "file": "src/routes/occurrences.tsx", "label": "Occurrences" },
    { "path": "/perfect", "file": "src/routes/perfect.tsx", "label": "Perfect Attendance" },
    { "path": "/trends", "file": "src/routes/trends.tsx", "label": "Trends" },
    { "path": "/headcount", "file": "src/routes/headcount.tsx", "label": "Headcount" }
  ],
  "workflow": {
    "ingest": [
      "Manager fills Microsoft Form (attendance + occurrence)",
      "Form syncs to Excel workbook",
      "Export workbook as CSV UTF-8",
      "Replace public/data/attendance.csv",
      "Commit + push to main",
      "GitHub Actions builds and deploys to Pages"
    ]
  },
  "limitations": [
    "No live webhook — data only as fresh as last commit",
    "No app-layer auth — gate via private repo / Pages access",
    "No PTO accrual or approval workflow",
    "No UI write-back to CSV"
  ]
}
